<Window x:Class="ClockSystem.SettingsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="报时系统设置"
        Width="800"
        Height="600"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResize">
    <Window.Resources>
        <ResourceDictionary>
            <!-- 现代化颜色方案 -->
            <SolidColorBrush x:Key="PrimaryColor" Color="#2C3E50"/>
            <SolidColorBrush x:Key="SecondaryColor" Color="#3498DB"/>
            <SolidColorBrush x:Key="AccentColor" Color="#E74C3C"/>
            <SolidColorBrush x:Key="LightColor" Color="#F8F9FA"/>
            <SolidColorBrush x:Key="DarkColor" Color="#2C3E50"/>
            <SolidColorBrush x:Key="TextColor" Color="#333333"/>
            <SolidColorBrush x:Key="BorderColor" Color="#E0E0E0"/>

            <!-- 按钮样式 -->
            <Style TargetType="Button">
                <Setter Property="Background" Value="{StaticResource SecondaryColor}"/>
                <Setter Property="Foreground" Value="White"/>
                <Setter Property="Padding" Value="10,5"/>
                <Setter Property="Margin" Value="5"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="FontSize" Value="14"/>
                <Style.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter Property="Background" Value="#2980B9"/>
                    </Trigger>
                    <Trigger Property="IsPressed" Value="True">
                        <Setter Property="Background" Value="#1F618D"/>
                    </Trigger>
                </Style.Triggers>
            </Style>

            <!-- 标签样式 -->
            <Style TargetType="Label">
                <Setter Property="Foreground" Value="{StaticResource TextColor}"/>
                <Setter Property="FontSize" Value="14"/>
                <Setter Property="Margin" Value="5"/>
            </Style>

            <!-- 文本框样式 -->
            <Style TargetType="TextBox">
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="BorderBrush" Value="{StaticResource BorderColor}"/>
                <Setter Property="Padding" Value="8"/>
                <Setter Property="Margin" Value="5"/>
                <Setter Property="FontSize" Value="14"/>
                <Setter Property="Width" Value="300"/>
                <Style.Triggers>
                    <Trigger Property="IsFocused" Value="True">
                        <Setter Property="BorderBrush" Value="{StaticResource SecondaryColor}"/>
                    </Trigger>
                </Style.Triggers>
            </Style>

            <!-- 复选框样式 -->
            <Style TargetType="CheckBox">
                <Setter Property="FontSize" Value="14"/>
                <Setter Property="Margin" Value="5"/>
            </Style>

            <!-- 选项卡样式 -->
            <Style TargetType="TabItem">
                <Setter Property="FontSize" Value="14"/>
                <Setter Property="Padding" Value="15,10"/>
            </Style>
        </ResourceDictionary>
    </Window.Resources>

    <Grid Background="#F5F5F5">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 选项卡控件 -->
        <TabControl Grid.Row="0" Margin="0,0,0,20">
            <!-- 文件路径选项卡 -->
            <TabItem Header="文件路径">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <!-- 音乐文件路径 -->
                        <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                            <Label Content="音乐文件:" VerticalAlignment="Center"/>
                            <TextBox Text="{Binding Path.MusicPath}" VerticalAlignment="Center"/>
                            <Button Content="浏览" Click="BrowseMusicButton_Click" VerticalAlignment="Center"/>
                        </StackPanel>

                        <!-- 钟声文件路径 -->
                        <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                            <Label Content="钟声文件:" VerticalAlignment="Center"/>
                            <TextBox Text="{Binding Path.BellPath}" VerticalAlignment="Center"/>
                            <Button Content="浏览" Click="BrowseBellButton_Click" VerticalAlignment="Center"/>
                        </StackPanel>

                        <!-- 整点报时路径 -->
                        <Label Content="整点报时语音路径" FontWeight="Bold" Margin="0,20,0,10"/>
                        <ItemsControl ItemsSource="{Binding Path.HourPaths}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" Margin="5">
                                        <Label Content="{Binding Key}" ContentStringFormat="{}{0}点:" Width="50"/>
                                        <TextBox Text="{Binding Value}" Width="200"/>
                                        <Button Content="浏览" Click="BrowseHourButton_Click" Tag="{Binding Key}"/>
                                    </StackPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <!-- 半点报时路径 -->
                        <Label Content="半点报时语音路径" FontWeight="Bold" Margin="0,20,0,10"/>
                        <ItemsControl ItemsSource="{Binding Path.HalfPaths}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" Margin="5">
                                        <Label Content="{Binding Key}" ContentStringFormat="{}{0}点半:" Width="60"/>
                                        <TextBox Text="{Binding Value}" Width="200"/>
                                        <Button Content="浏览" Click="BrowseHalfButton_Click" Tag="{Binding Key}"/>
                                    </StackPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- 报时开关选项卡 -->
            <TabItem Header="报时开关">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <!-- 整点报时开关 -->
                        <Label Content="整点报时开关" FontWeight="Bold" Margin="0,10,0,10"/>
                        <UniformGrid Columns="6">
                            <ItemsControl ItemsSource="{Binding Switch.HourSwitches}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Margin="5" HorizontalAlignment="Center">
                                            <CheckBox IsChecked="{Binding Value}" Content="{Binding Key}" ContentStringFormat="{}{0}点"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </UniformGrid>

                        <!-- 半点报时开关 -->
                        <Label Content="半点报时开关" FontWeight="Bold" Margin="0,20,0,10"/>
                        <UniformGrid Columns="6">
                            <ItemsControl ItemsSource="{Binding Switch.HalfSwitches}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Margin="5" HorizontalAlignment="Center">
                                            <CheckBox IsChecked="{Binding Value}" Content="{Binding Key}" ContentStringFormat="{}{0}点半"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </UniformGrid>

                        <!-- 全选按钮 -->
                        <StackPanel Orientation="Horizontal" Margin="0,20,0,0">
                            <Button Content="整点全选" Click="SelectAllHourButton_Click"/>
                            <Button Content="整点全不选" Click="DeselectAllHourButton_Click"/>
                            <Button Content="半点全选" Click="SelectAllHalfButton_Click"/>
                            <Button Content="半点全不选" Click="DeselectAllHalfButton_Click"/>
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- 灯光设置选项卡 -->
            <TabItem Header="灯光设置">
                <StackPanel>
                    <!-- 灯光开启时间 -->
                    <StackPanel Orientation="Horizontal" Margin="0,20,0,0">
                        <Label Content="灯光开启时间:" VerticalAlignment="Center"/>
                        <TextBox Text="{Binding Light.LightOnTime}" VerticalAlignment="Center" Width="100"/>
                        <Label Content="格式：HH:MM" VerticalAlignment="Center" Margin="10,0,0,0"/>
                    </StackPanel>

                    <!-- 灯光关闭时间 -->
                    <StackPanel Orientation="Horizontal" Margin="0,20,0,0">
                        <Label Content="灯光关闭时间:" VerticalAlignment="Center"/>
                        <TextBox Text="{Binding Light.LightOffTime}" VerticalAlignment="Center" Width="100"/>
                        <Label Content="格式：HH:MM" VerticalAlignment="Center" Margin="10,0,0,0"/>
                    </StackPanel>
                </StackPanel>
            </TabItem>
        </TabControl>

        <!-- 按钮区域 -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="保存" Click="SaveButton_Click"/>
            <Button Content="取消" Click="CancelButton_Click"/>
        </StackPanel>
    </Grid>
</Window>